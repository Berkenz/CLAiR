# Database
DATABASE_URL=postgresql+asyncpg://clair_user:clair_password@db:5432/clair_db

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
# Path to service account JSON (download from Firebase Console > Project Settings > Service Accounts)
FIREBASE_SERVICE_ACCOUNT_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LLM (optional fallbacks)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# File storage — GCS (recommended) or supabase
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=clair-uploads
GCS_PROJECT_ID=your-gcp-project-id

# Vertex AI — GCP credits (copy JSON to backend/gcp-vertex-key.json)
GCP_PROJECT_ID=
GCP_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-vertex-key.json
GCP_VERTEX_CREDENTIALS_PATH=/app/gcp-vertex-key.json
VERTEX_CHAT_MODEL=gemini-2.5-flash
VERTEX_TITLE_MODEL=gemini-2.5-flash

# Mobile push (FCM) — uses same Firebase service account as auth
PUSH_NOTIFICATIONS_ENABLED=true

# Chat rate limits (per Firebase user id on POST /api/v1/chat/send)
CHAT_RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_REGISTERED=15/minute
CHAT_RATE_LIMIT_ANONYMOUS=5/minute

# Environment
ENVIRONMENT=development
DEBUG=true
