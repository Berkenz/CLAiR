# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Firebase ───────────────────────────────────────────────────────────────────
# Paste the full service-account JSON as a single-line string (escape newlines as \n)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"..."}'
FIREBASE_WEB_API_KEY=AIzaSy...

# ── File storage (profile photos, attachments, PDF cache) ─────────────────────
# supabase = Supabase Storage (free tier ~50MB total) | gcs = Google Cloud Storage
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=clair-uploads
GCS_PROJECT_ID=your-gcp-project-id
# Same JSON as Vertex (Agent Platform User + Storage Object Admin on bucket)
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-vertex-key.json
GCP_VERTEX_CREDENTIALS_PATH=/app/gcp-vertex-key.json
# Render / cloud hosts: paste full JSON here (one line) instead of a file path
GCP_SERVICE_ACCOUNT_JSON=

# ── Supabase (optional if STORAGE_BACKEND=gcs; still needed only for legacy URLs) ─
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Postgres URL for pgvector RAG on your VM (not Supabase hosted storage)
SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname

# ── LLM providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...
TAVILY_API_KEY=tvly-...

# ── RAG embedding service ──────────────────────────────────────────────────────
EMBED_SERVICE_URL=http://your-vm-ip:8001

# ── SMTP (for report notification emails) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
REPORT_RECIPIENT_EMAIL=support@yourdomain.com

# ── CORS ───────────────────────────────────────────────────────────────────────
# JSON array of allowed origins (production: your deployed front-end URLs)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://clair-ai.app","https://www.clair-ai.app"]

# ── Mobile push (FCM) ───────────────────────────────────────────────────────────
PUSH_NOTIFICATIONS_ENABLED=true

# ── Chat rate limits (per Firebase user id) ────────────────────────────────────
CHAT_RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_REGISTERED=15/minute
CHAT_RATE_LIMIT_ANONYMOUS=5/minute

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
