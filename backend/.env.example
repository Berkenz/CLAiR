DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clair_db
FIREBASE_PROJECT_ID=your-firebase-project-id

# Supabase (for profile photo storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Comma-separated or JSON array, e.g. CORS_ORIGINS='["http://localhost:3000"]'
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
# GEMINI_TITLE_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=your-groq-api-key
# Optional fallbacks when Groq/Gemini rate limit (OpenRouter free models)
OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_CHAT_MODEL=openrouter/free
# OPENROUTER_TITLE_MODEL=openrouter/free
# Tavily (real-time web search, domain-restricted to trusted PH legal sites)
TAVILY_API_KEY=your-tavily-api-key
# Chat latency tuning (optional)
# CHAT_MAX_TOKENS=768
# CHAT_USE_FAST_MODEL_FOR_SHORT=true
# GROQ_FAST_CHAT_MODEL=llama-3.1-8b-instant
# TAVILY_TIMEOUT_SECONDS=2.5
# LAWYER_DIRECTORY_CACHE_TTL_SECONDS=300
ENVIRONMENT=development
DEBUG=false
APP_NAME=CLAiR API
APP_VERSION=0.1.0
#
#