# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Firebase ───────────────────────────────────────────────────────────────────
# Paste the full service-account JSON as a single-line string (escape newlines as \n)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"..."}'
FIREBASE_WEB_API_KEY=AIzaSy...

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Postgres URL for pgvector RAG (can be same host as DATABASE_URL, no +asyncpg)
SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname

# ── LLM providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...
TAVILY_API_KEY=tvly-...

# ── RAG embedding service ──────────────────────────────────────────────────────
EMBED_SERVICE_URL=http://your-vm-ip:8001

# ── SMTP (for report notification emails) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
REPORT_RECIPIENT_EMAIL=support@yourdomain.com

# ── CORS ───────────────────────────────────────────────────────────────────────
# JSON array of allowed origins (production: your deployed front-end URLs)
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
